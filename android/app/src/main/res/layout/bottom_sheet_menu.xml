<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/sheet_background"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_sheet_handle" />

    <!-- Quick actions row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <!-- New Tab -->
        <LinearLayout
            android:id="@+id/menu_new_tab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:src="@drawable/ic_add" style="@style/MenuIconStyle"
                android:layout_width="28dp" android:layout_height="28dp" />
            <TextView android:text="@string/new_tab" android:textColor="@color/text_secondary"
                android:textSize="10sp" android:layout_marginTop="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Incognito -->
        <LinearLayout
            android:id="@+id/menu_incognito_tab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:src="@drawable/ic_incognito" style="@style/MenuIconStyle"
                android:layout_width="28dp" android:layout_height="28dp" />
            <TextView android:text="@string/incognito_tab" android:textColor="@color/text_secondary"
                android:textSize="10sp" android:layout_marginTop="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Share -->
        <LinearLayout
            android:id="@+id/menu_share"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:src="@drawable/ic_share" style="@style/MenuIconStyle"
                android:layout_width="28dp" android:layout_height="28dp" />
            <TextView android:text="@string/share" android:textColor="@color/text_secondary"
                android:textSize="10sp" android:layout_marginTop="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Find -->
        <LinearLayout
            android:id="@+id/menu_find_in_page"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:src="@drawable/ic_search" style="@style/MenuIconStyle"
                android:layout_width="28dp" android:layout_height="28dp" />
            <TextView android:text="@string/find" android:textColor="@color/text_secondary"
                android:textSize="10sp" android:layout_marginTop="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>

    <View style="@style/MenuDivider" />

    <!-- Bookmark this page -->
    <LinearLayout android:id="@+id/menu_bookmark"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_bookmark" style="@style/MenuIconStyle" />
        <TextView android:text="@string/add_bookmark" style="@style/MenuTextStyle" />
    </LinearLayout>

    <!-- Bookmarks list -->
    <LinearLayout android:id="@+id/menu_bookmarks"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_bookmark_filled" style="@style/MenuIconStyle" />
        <TextView android:text="@string/bookmarks" style="@style/MenuTextStyle" />
    </LinearLayout>

    <!-- History -->
    <LinearLayout android:id="@+id/menu_history"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_history" style="@style/MenuIconStyle" />
        <TextView android:text="@string/history" style="@style/MenuTextStyle" />
    </LinearLayout>

    <!-- Downloads -->
    <LinearLayout android:id="@+id/menu_downloads"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_download" style="@style/MenuIconStyle" />
        <TextView android:text="@string/downloads" style="@style/MenuTextStyle" />
    </LinearLayout>

    <View style="@style/MenuDivider" />

    <!-- Save History Toggle -->
    <LinearLayout android:id="@+id/menu_save_history_container"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_history" style="@style/MenuIconStyle" />
        <TextView android:text="@string/save_history" style="@style/MenuTextStyle"
            android:layout_weight="1" />
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_save_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
    </LinearLayout>

    <!-- Desktop Site -->
    <LinearLayout android:id="@+id/menu_desktop_site"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_desktop" style="@style/MenuIconStyle" />
        <TextView android:text="@string/desktop_site" style="@style/MenuTextStyle"
            android:layout_weight="1" />
        <ImageView android:id="@+id/ic_check_desktop"
            android:src="@drawable/ic_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone" />
    </LinearLayout>

    <View style="@style/MenuDivider" />

    <!-- Settings -->
    <LinearLayout android:id="@+id/menu_settings"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_settings" style="@style/MenuIconStyle" />
        <TextView android:text="@string/settings" style="@style/MenuTextStyle" />
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/sheet_background"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_sheet_handle" />

    <!-- Quick actions row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <!-- New Tab -->
        <LinearLayout
            android:id="@+id/menu_new_tab"
            style="@style/QuickActionStyle">
            <ImageView
                android:src="@drawable/ic_add"
                style="@style/QuickActionIconStyle" />
            <TextView
                android:text="@string/new_tab"
                style="@style/QuickActionTextStyle" />
        </LinearLayout>

        <!-- Incognito -->
        <LinearLayout
            android:id="@+id/menu_incognito_tab"
            style="@style/QuickActionStyle">
            <ImageView
                android:src="@drawable/ic_incognito"
                style="@style/QuickActionIconStyle" />
            <TextView
                android:text="@string/incognito_tab"
                style="@style/QuickActionTextStyle" />
        </LinearLayout>

        <!-- Share -->
        <LinearLayout
            android:id="@+id/menu_share"
            style="@style/QuickActionStyle">
            <ImageView
                android:src="@drawable/ic_share"
                style="@style/QuickActionIconStyle" />
            <TextView
                android:text="@string/share"
                style="@style/QuickActionTextStyle" />
        </LinearLayout>

        <!-- Find -->
        <LinearLayout
            android:id="@+id/menu_find_in_page"
            style="@style/QuickActionStyle">
            <ImageView
                android:src="@drawable/ic_search"
                style="@style/QuickActionIconStyle" />
            <TextView
                android:text="@string/find"
                style="@style/QuickActionTextStyle" />
        </LinearLayout>
    </LinearLayout>

    <View style="@style/MenuDivider" />

    <!-- Bookmark this page -->
    <LinearLayout android:id="@+id/menu_bookmark"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_bookmark" style="@style/MenuIconStyle" />
        <TextView android:text="@string/add_bookmark" style="@style/MenuTextStyle" />
    </LinearLayout>

    <!-- Bookmarks list -->
    <LinearLayout android:id="@+id/menu_bookmarks"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_bookmark_filled" style="@style/MenuIconStyle" />
        <TextView android:text="@string/bookmarks" style="@style/MenuTextStyle" />
    </LinearLayout>

    <!-- History -->
    <LinearLayout android:id="@+id/menu_history"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_history" style="@style/MenuIconStyle" />
        <TextView android:text="@string/history" style="@style/MenuTextStyle" />
    </LinearLayout>

    <!-- Downloads -->
    <LinearLayout android:id="@+id/menu_downloads"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_download" style="@style/MenuIconStyle" />
        <TextView android:text="@string/downloads" style="@style/MenuTextStyle" />
    </LinearLayout>

    <View style="@style/MenuDivider" />

    <!-- Save History Toggle -->
    <LinearLayout android:id="@+id/menu_save_history_container"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_history" style="@style/MenuIconStyle" />
        <TextView android:text="@string/save_history" style="@style/MenuTextStyle"
            android:layout_weight="1" />
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_save_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
    </LinearLayout>

    <!-- Desktop Site -->
    <LinearLayout android:id="@+id/menu_desktop_site"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_desktop" style="@style/MenuIconStyle" />
        <TextView android:text="@string/desktop_site" style="@style/MenuTextStyle"
            android:layout_weight="1" />
        <ImageView android:id="@+id/ic_check_desktop"
            android:src="@drawable/ic_check"
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:tint="@color/accent_purple"
            android:visibility="gone" />
    </LinearLayout>

    <View style="@style/MenuDivider" />

    <!-- Print -->
    <LinearLayout android:id="@+id/menu_print"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_print" style="@style/MenuIconStyle" />
        <TextView android:text="@string/print_page" style="@style/MenuTextStyle" />
    </LinearLayout>

    <!-- Add to Home Screen -->
    <LinearLayout android:id="@+id/menu_add_to_home"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_add_to_home" style="@style/MenuIconStyle" />
        <TextView android:text="@string/add_to_home" style="@style/MenuTextStyle" />
    </LinearLayout>

    <View style="@style/MenuDivider" />

    <!-- Settings -->
    <LinearLayout android:id="@+id/menu_settings"
        style="@style/MenuItemStyle">
        <ImageView android:src="@drawable/ic_settings" style="@style/MenuIconStyle" />
        <TextView android:text="@string/settings" style="@style/MenuTextStyle" />
    </LinearLayout>
</LinearLayout>

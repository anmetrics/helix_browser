<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.MainActivity">

    <!-- ── TOP & CONTENT COORDINATOR ── -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsingLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/toolbar_background"
                app:contentScrim="@color/toolbar_background"
                app:layout_scrollFlags="scroll|exitUntilCollapsed|enterAlways"
                app:elevation="0dp">

                <!-- ── TOP TOOLBAR (Slides behind) ── -->
                <LinearLayout
                    android:id="@+id/toolbarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/toolbar_background"
                    app:layout_collapseMode="parallax">

                    <!-- Padding space corresponding to status bar -->
                    <View
                        android:id="@+id/statusBarPadding"
                        android:layout_width="match_parent"
                        android:layout_height="0dp" />

                    <!-- Desktop Tab Bar (tablet only) -->
                    <include layout="@layout/desktop_tab_bar" />

                    <!-- Address bar row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:id="@+id/iconSecure"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:padding="5dp"
                            android:src="@drawable/ic_lock"
                            android:visibility="gone"
                            android:contentDescription="@string/desc_secure" />

                        <EditText
                            android:id="@+id/addressBar"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_address_bar"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="0dp"
                            android:hint="@string/search_hint"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/hint_color"
                            android:textSize="14sp"
                            android:singleLine="true"
                            android:imeOptions="actionGo"
                            android:inputType="textUri"
                            android:selectAllOnFocus="true"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:fontFamily="sans-serif" />

                        <ImageButton
                            android:id="@+id/btnBookmark"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:padding="6dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_bookmark"
                            android:contentDescription="@string/desc_bookmark" />

                        <ImageButton
                            android:id="@+id/btnRefresh"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:padding="6dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_refresh"
                            android:contentDescription="@string/desc_refresh" />

                        <TextView
                            android:id="@+id/btnCancelSearch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cancel"
                            android:textColor="@color/accent_purple"
                            android:textSize="14sp"
                            android:paddingHorizontal="8dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Loading progress -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:max="100"
                        android:progress="0"
                        android:visibility="gone"
                        app:indicatorColor="@color/accent_purple"
                        app:trackColor="@android:color/transparent"
                        app:trackThickness="3dp" />

                    <!-- Incognito indicator -->
                    <TextView
                        android:id="@+id/incognitoIndicator"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:background="@color/incognito_background"
                        android:gravity="center"
                        android:text="@string/incognito_mode"
                        android:textColor="#ffffff"
                        android:textSize="11sp"
                        android:visibility="gone" />
                    
                    <!-- FIND IN PAGE BAR (part of the sliding unit) -->
                    <LinearLayout
                        android:id="@+id/findInPageBar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:background="@color/toolbar_background"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/findInPageInput"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_address_bar"
                            android:paddingHorizontal="12dp"
                            android:hint="@string/find_in_page"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:focusable="true"
                            android:focusableInTouchMode="true" />

                        <ImageButton
                            android:id="@+id/btnFindPrev"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_arrow_up"
                            android:contentDescription="@string/desc_prev" />

                        <ImageButton
                            android:id="@+id/btnFindNext"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_arrow_down"
                            android:contentDescription="@string/desc_next" />

                        <ImageButton
                            android:id="@+id/btnCloseFindInPage"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_close"
                            android:contentDescription="@string/desc_close" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── PINNED STATUS BAR AREA ── -->
                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="@color/toolbar_background"
                    app:layout_collapseMode="pin"
                    android:contentInsetStart="0dp"
                    android:contentInsetLeft="0dp"
                    app:contentInsetStart="0dp"
                    app:contentInsetLeft="0dp">

                    <View
                        android:id="@+id/statusBarSpace"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:background="@color/toolbar_background" />
                </androidx.appcompat.widget.Toolbar>

            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:id="@+id/webViewContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ── BOTTOM NAVIGATION ── -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/toolbar_background"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Top separator with subtle gradient accent -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color" />

        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    android:alpha="0.4"
                    android:padding="10dp"
                    android:contentDescription="@string/desc_back" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btnForward"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_forward"
                    android:alpha="0.4"
                    android:padding="10dp"
                    android:contentDescription="@string/desc_forward" />
            </FrameLayout>

            <!-- Home button - center, slightly larger -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btnHome"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_home"
                    android:padding="9dp"
                    android:contentDescription="@string/desc_home" />
            </FrameLayout>

            <!-- Tab counter with pill background -->
            <FrameLayout
                android:id="@+id/btnTabs"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:id="@+id/tabCountBadge"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:text="1"
                    android:textColor="@color/accent_purple"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_tab_count_badge" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_more_vert"
                    android:padding="10dp"
                    android:contentDescription="@string/desc_more" />
            </FrameLayout>
        </LinearLayout>

        <View
            android:id="@+id/navBarSpace"
            android:layout_width="match_parent"
            android:layout_height="0dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

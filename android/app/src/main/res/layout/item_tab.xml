<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_margin="6dp"
    app:cardCornerRadius="18dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Thumbnail / Preview -->
        <ImageView
            android:id="@+id/tabThumbnail"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:background="@color/card_background"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tabInfoBar"
            tools:ignore="ContentDescription" />

        <!-- Gradient overlay on thumbnail for smooth transition -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_tab_thumbnail_overlay"
            app:layout_constraintBottom_toTopOf="@+id/tabInfoBar" />

        <!-- Active tab glow indicator (top edge) -->
        <View
            android:id="@+id/activeIndicator"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/bg_bottom_nav_indicator"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Incognito badge -->
        <TextView
            android:id="@+id/incognitoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_incognito_badge"
            android:text="Private"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Info bar with favicon -->
        <LinearLayout
            android:id="@+id/tabInfoBar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@color/card_background"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Favicon -->
            <ImageView
                android:id="@+id/tabFavicon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_helix_logo"
                android:scaleType="centerCrop"
                tools:ignore="ContentDescription" />

            <!-- Incognito icon (shown instead of favicon in private mode) -->
            <ImageView
                android:id="@+id/incognitoIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_incognito"
                android:visibility="gone"
                tools:ignore="ContentDescription" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tabTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    tools:text="Google" />

                <TextView
                    android:id="@+id/tabUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="1dp"
                    tools:text="google.com" />
            </LinearLayout>

            <!-- Close button with ripple -->
            <ImageButton
                android:id="@+id/btnCloseTab"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:alpha="0.6"
                android:contentDescription="Close tab" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
